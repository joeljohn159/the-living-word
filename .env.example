# Turso Database (required for production on Vercel)
# Get these from: turso db show <db-name> --url / turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Local development uses file:data/bible.db automatically (no env vars needed)

# Site URL for metadata / Open Graph
NEXT_PUBLIC_SITE_URL=https://thelivingword.app

# Analytics (optional)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=thelivingword.app
